    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  const content = item.json.choices[0].message.content;\n\n  const subjectMatch = content.match(/Subject:\\s*(.*)/i);\n  const subject = subjectMatch ? subjectMatch[1].trim() : \"AI automation idea\";\n\n  const body = content.replace(/Subject:.*\\n/i, \"\").trim();\n\n  return {\n    json: {\n      firstname: item.json.firstname,\n      email: item.json.email,\n      company: item.json.company,\n      subject: subject,\n      email_body: body\n    }\n  };\n});"
      },
