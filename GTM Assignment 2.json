        "jsCode": "return items.map(item => {\n  return {\n    json: {\n      firstname: item.json.properties.firstname?.value || \"\",\n      lastname: item.json.properties.lastname?.value || \"\",\n      email: item.json[\"identity-profiles\"][0].identities\n        .find(i => i.type === \"EMAIL\")?.value || \"\",\n      linkedin_url: item.json.properties.hs_linkedin_url?.value || \"\",\n      jobtitle: item.json.properties.jobtitle?.value || \"\",\n      company: item.json.properties.company?.value || \"\",\n      about: item.json.properties.about?.value || \"\",\n      bio: item.json.properties.linkedin_headline?.value || \"\",\n    }\n  };\n});"
